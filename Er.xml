-------------------------
processQuery()
retrieveContext()
generateResponse()" style="shape=rectangle;whiteSpace=wrap;rounded=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="480" y="240" width="240" height="180" as="geometry"/>
