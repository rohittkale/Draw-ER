-------------------------
userId
name
email
phone
role
-------------------------
register()
login()
searchProperty()" style="shape=rectangle;whiteSpace=wrap;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="180" height="140" as="geometry"/>
        </mxCell>

        <!-- AGENT -->
        <mxCell id="agent" value="Agent
-------------------------
agentId
name
licenseNo
agency
-------------------------
addProperty()
manageAppointments()" style="shape=rectangle;whiteSpace=wrap;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="260" y="40" width="180" height="140" as="geometry"/>
        </mxCell>

        <!-- PROPERTY -->
        <mxCell id="property" value="Property
-------------------------
propertyId
title
price
location
type
-------------------------
updateDetails()" style="shape=rectangle;whiteSpace=wrap;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="40" width="200" height="160" as="geometry"/>
        </mxCell>

